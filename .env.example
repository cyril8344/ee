# ============================================================================
# XAU/USD Scalping Bot — environment configuration
# Copy this file to ".env" (same directory) and fill in what you need.
# All keys are optional: without any, the bot uses yfinance (≈60d M5) and
# falls back to a deterministic synthetic feed when offline.
# ============================================================================

# --- Market data provider --------------------------------------------------
# One of: auto | twelvedata | polygon | alphavantage | yfinance | synthetic
# "auto" tries providers whose key is set, in this order:
#   twelvedata -> polygon -> alphavantage -> yfinance -> synthetic
XAU_DATA_PROVIDER=auto

# Twelve Data  (https://twelvedata.com)  — supports "XAU/USD" directly
TWELVEDATA_API_KEY=

# Polygon.io  (https://polygon.io)  — ticker X:XAUUSD
POLYGON_API_KEY=

# Alpha Vantage  (https://www.alphavantage.co)  — FX_INTRADAY XAU/USD
ALPHAVANTAGE_API_KEY=

# --- Optional symbol overrides (defaults are usually fine) ------------------
# XAU_TD_SYMBOL=XAU/USD
# XAU_POLY_SYMBOL=X:XAUUSD
# XAU_YF_SYMBOL=GC=F

# --- Database --------------------------------------------------------------
# XAU_DB_PATH=/absolute/path/to/xau_bot.db

# --- Frontend --------------------------------------------------------------
# URL of the backend API as seen by the browser (leave blank to use the Vite
# dev proxy). For docker-compose this is set automatically.
# VITE_API_URL=http://localhost:8000
